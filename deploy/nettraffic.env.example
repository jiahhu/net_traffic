# HTTP 服务地址。若使用 Nginx 反代，建议改为 127.0.0.1:8080。
NETTRAFFIC_LISTEN=:8080

# 留空时自动使用默认路由网卡，例如 eth0、ens3。
NETTRAFFIC_INTERFACE=
NETTRAFFIC_DB=/var/lib/nettraffic/nettraffic.db
NETTRAFFIC_INTERVAL=2s
NETTRAFFIC_RETENTION_DAYS=90

# 建议在公网开放页面时设置登录凭据。
NETTRAFFIC_USERNAME=
NETTRAFFIC_PASSWORD=

# 目标网站排行。反向 DNS 可关闭，但关闭后只显示 IP。
NETTRAFFIC_CONNTRACK=/proc/net/nf_conntrack
NETTRAFFIC_RESOLVE_HOSTNAMES=true

